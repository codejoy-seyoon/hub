# ============================================================
# BNI Hub — 환경변수 템플릿
# 이 파일을 복사해 `.env.local` 로 만들고 값을 채우세요.
#   cp .env.local.example .env.local
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# anon(공개) 키 — 브라우저에 노출되어도 되는 키
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# service role 키 — 서버 전용. 절대 NEXT_PUBLIC_ 접두사 금지, 절대 커밋 금지
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ---- Toss Payments ----
# ⚠️ 개발/테스트는 반드시 test 키 사용 (live 키는 실제 카드가 청구됩니다)
# client 키: 브라우저(결제위젯)용
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxxxxxx
# secret 키: 서버(승인 API)용. 절대 NEXT_PUBLIC_ 접두사 금지, 절대 커밋 금지
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# ---- 앱 ----
# 결제 리다이렉트(successUrl/failUrl)에 쓰는 사이트 기준 URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
